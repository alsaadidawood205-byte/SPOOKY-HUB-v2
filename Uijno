        local function throwBombs()
            local thrown = 0
            local tools = {}
            if LocalPlayer:FindFirstChild("Backpack") then
                for _, t in ipairs(LocalPlayer.Backpack:GetChildren()) do
                    if t:IsA("Tool") and t.Name:lower():find("bomb") then
