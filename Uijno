-- متغيرات لتخزين الاتصالات النشطة
local activeConnections = {
    bang = nil,
    bangBack = nil,
    faceBang = nil,
    faceBangBack = nil
}

-- دالة إيقاف كل البانجات
local function stopAllBangs()
    for _, conn in pairs(activeConnections) do
        if conn then
            conn:Disconnect()
        end
    end
    activeConnections = {bang = nil, bangBack = nil, faceBang = nil, faceBangBack = nil}
    
    local player = game.Players.LocalPlayer
    if player and player.Character then
        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
end

-- دالة مساعدة لإنشاء التوجل (Toggle) مع الحركة التذبذبية
local function createBangToggle(name, getPositionCFrame)
    MercyTab:AddToggle({
        Name = name,
        Default = false,
        Callback = function(state)
            local player = game.Players.LocalPlayer
            if not player then return end
            
            if state then
                -- إيقاف أي بانج آخر نشط
                stopAllBangs()
                
                local character = player.Character
                if not character then return end
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid.PlatformStand = true
                end
                
                -- إنشاء الاتصال الجديد
                local connection = game:GetService("RunService").Heartbeat:Connect(function()
                    local targetName = getgenv().selectedPlayer
                    if not targetName then return end
                    
                    local target = game.Players:FindFirstChild(targetName)
                    if not target or not target.Character then return end
                    
                    local newCFrame = getPositionCFrame(target.Character, player.Character)
                    if newCFrame and player.Character then
                        player.Character:SetPrimaryPartCFrame(newCFrame)
                    end
                end)
                
                -- تخزين الاتصال حسب اسم الزر
                if name == "Bang" then
                    activeConnections.bang = connection
                elseif name == "Bang خلفي" then
                    activeConnections.bangBack = connection
                elseif name == "الوجه Bang" then
                    activeConnections.faceBang = connection
                elseif name == "الوجه Bang 2" then
                    activeConnections.faceBangBack = connection
                end
            else
                -- إيقاف هذا البانج فقط
                if name == "Bang" and activeConnections.bang then
                    activeConnections.bang:Disconnect()
                    activeConnections.bang = nil
                elseif name == "Bang خلفي" and activeConnections.bangBack then
                    activeConnections.bangBack:Disconnect()
                    activeConnections.bangBack = nil
                elseif name == "الوجه Bang" and activeConnections.faceBang then
                    activeConnections.faceBang:Disconnect()
                    activeConnections.faceBang = nil
                elseif name == "الوجه Bang 2" and activeConnections.faceBangBack then
                    activeConnections.faceBangBack:Disconnect()
                    activeConnections.faceBangBack = nil
                end
                
                -- إذا لم يعد هناك أي بانج نشط، قم بإلغاء PlatformStand
                local anyActive = false
                for _, conn in pairs(activeConnections) do
                    if conn then anyActive = true; break end
                end
                if not anyActive then
                    local character = player.Character
                    if character then
                        local humanoid = character:FindFirstChildOfClass("Humanoid")
                        if humanoid then
                            humanoid.PlatformStand = false
                        end
                    end
                end
            end
        end
    })
end

-- تعريف وظائف المواقع لكل نوع بانج
-- 1. Bang (أمامي)
createBangToggle("Bang", function(targetChar, localChar)
    local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return nil end
    local offset = math.sin(tick() * 2.5) * 1.5
    local distance = 3 + offset  -- يتحرك بين 1.5 و 4.5
    return targetHRP.CFrame * CFrame.new(0, -1, distance) * CFrame.Angles(0, math.rad(180), 0)
end)

-- 2. Bang خلفي (خلف الظهر)
createBangToggle("Bang خلفي", function(targetChar, localChar)
    local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return nil end
    local backDirection = targetHRP.CFrame.LookVector * -1
    local offset = math.sin(tick() * 2.5) * 1.5
    local distance = 2.5 + offset  -- يتحرك بين 1 و 4
    local pos = targetHRP.Position + backDirection * distance
    return CFrame.new(pos, targetHRP.Position) * CFrame.Angles(0, math.rad(180), 0)
end)

-- 3. الوجه Bang (أمام الوجه)
createBangToggle("الوجه Bang", function(targetChar, localChar)
    local targetHead = targetChar:FindFirstChild("Head")
    if not targetHead then return nil end
    local offset = math.sin(tick() * 3) * 1.5
    local distance = 1.5 + offset  -- يتحرك بين 0 و 3
    return targetHead.CFrame * CFrame.new(0, 0.5, -distance) * CFrame.Angles(0, math.rad(180), 0)
end)

-- 4. الوجه Bang 2 (خلف الرأس)
createBangToggle("الوجه Bang 2", function(targetChar, localChar)
    local targetHead = targetChar:FindFirstChild("Head")
    if not targetHead then return nil end
    local offset = math.sin(tick() * 3) * 1
    local distance = 1.2 + offset  -- يتحرك بين 0.2 و 2.2
    return targetHead.CFrame * CFrame.new(0, 0, distance) * CFrame.Angles(0, math.rad(180), 0)
end)

