-- تبويب المتعه
-- ═══════════════════════════════════════
local FunTab = Window:CreateTab("المتعه", 4483362458)

FunTab:CreateInput({
    Name = "اسم الضحية",
    PlaceholderText = "اكتب جزء من الاسم...",
    Callback = function(text)
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(text:lower()) and p ~= lp then
                bangTarget = p
                Rayfield:Notify({ Title = "المتعه", Content = "تم تحديد: " .. p.Name, Duration = 3 })
                return
            end
        end
        bangTarget = nil
    end
})

FunTab:CreateToggle({
    Name = "تفعيل Bang",
    CurrentValue = false,
    Callback = function(state)
        bangEnabled = state
        faceSitEnabled = false
    end
})

FunTab:CreateToggle({
    Name = "تفعيل FaceSit",
    CurrentValue = false,
    Callback = function(state)
        faceSitEnabled = state
        bangEnabled = false
    end
})

RunService.Heartbeat:Connect(function()
    pcall(function()
        if (faceSitEnabled or bangEnabled) and bangTarget and bangTarget.Character then
            local targetChar = bangTarget.Character
            local hrp = lp.Character.HumanoidRootPart
            local move = math.sin(tick() * 150) * 1.5
            hrp.Velocity = Vector3.zero
            if faceSitEnabled and targetChar:FindFirstChild("Head") then
                lp.Character.Humanoid.Sit = true
                hrp.CFrame = targetChar.Head.CFrame * CFrame.new(0, 0.2, -0.5 + move) * CFrame.Angles(0, math.rad(180), 0)
            elseif bangEnabled then
                lp.Character.Humanoid.Sit = false
                hrp.CFrame = targetChar.HumanoidRootPart.CFrame * CFrame.new(0, 0.5, 1.1 + move)
            end
        end
    end)
end)

