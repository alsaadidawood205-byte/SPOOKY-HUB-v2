-- تبويب الفلنق (المطور)
-- ═══════════════════════════════════════
local FlingTab = Window:CreateTab(" الفلنق", 4483362458)

FlingTab:CreateSection("فلنق بالكنبة")

FlingTab:CreateButton({
    Name = "اخذ الكنبة",
    Callback = function()
        pcall(function()
            local args = {[1] = "PickingTools", [2] = "Couch"}
            ReplicatedStorage.RE:FindFirstChild("1Too1l"):InvokeServer(unpack(args))
        end)
        Rayfield:Notify({ Title = "الفلنق", Content = "تم اخذ الكنبة!", Duration = 3 })
    end
})

FlingTab:CreateInput({
    Name = "اكتب اسم الضحية",
    PlaceholderText = "اكتب الاسم هنا...",
    RemoveTextAfterFocusLost = false,
    Callback = function(text)
        local searchText = text:lower()
        if #searchText >= 1 then
            for _, p in pairs(Players:GetPlayers()) do
                if p.Name:lower():find(searchText) and p ~= lp then
                    selectedFlingPlayer = p
                    Rayfield:Notify({ Title = "الفلنق", Content = "تم تحديد: " .. p.Name, Duration = 3 })
                    return
                end
            end
        end
        selectedFlingPlayer = nil
    end
})

FlingTab:CreateToggle({
    Name = "قتل اللاعب بالكنبة",
    CurrentValue = false,
    Callback = function(state)
        if state then
            if not selectedFlingPlayer then
                Rayfield:Notify({ Title = "خطأ", Content = "اختر لاعب اولاً!", Duration = 3 })
                return
            end
            getgenv().flingloop = true
            task.spawn(function()
                while getgenv().flingloop do
                    pcall(function()
                        local target = selectedFlingPlayer
                        if not target or not target.Character then return end
                        local char = lp.Character
                        local rootPart = char:FindFirstChild("HumanoidRootPart")
                        local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
                        if rootPart and tRoot then
                           rootPart.CFrame = tRoot.CFrame * CFrame.new(0, 1.5, 0)
                           rootPart.Velocity = Vector3.new(9e7, 9e7, 9e7)
                        end
                    end)
                    task.wait()
                end
            end)
        else
            getgenv().flingloop = false
        end
    end
})

